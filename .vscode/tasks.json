{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Docker: Rebuild & Up",
      "type": "shell",
      "command": "docker compose down --timeout=0 && docker compose build && docker compose up -d && docker compose logs -f",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      },
      "runOptions": {
        "instanceLimit": 1,
        "reevaluateOnRerun": true
      },
      "problemMatcher": []
    }
  ]
}
