{
  "name": "api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc && cp src/parsers/*.peggy dist/parsers/ 2>/dev/null || true && cp -r src/db/migrations dist/db/ 2>/dev/null || true && cp src/db/seed.ts dist/db/ 2>/dev/null || true",
    "start": "node dist/index.js",
    "lint": "eslint src/",
    "test": "vitest run",
    "provision-user": "tsx src/db/provisionUser.ts",
    "audit": "npm audit --production"
  },
  "dependencies": {
    "argon2": "^0.45.0",
    "bcrypt": "^5.1.1",
    "cookie-parser": "^1.4.7",
    "express": "^4.21.0",
    "express-rate-limit": "^8.5.2",
    "helmet": "^7.1.0",
    "peggy": "^4.1.1",
    "pg": "^8.13.0",
    "redis": "^6.1.0",
    "sanitize-html": "^2.17.6",
    "socket.io": "^4.8.0",
    "uuid": "^11.1.1",
    "zxcvbn": "^4.4.2"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.0",
    "@types/node": "^22.7.0",
    "@types/pg": "^8.11.10",
    "@types/sanitize-html": "^2.16.1",
    "@types/supertest": "^7.2.1",
    "@types/zxcvbn": "^4.4.5",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^9.11.0",
    "fast-check": "^4.9.0",
    "supertest": "^7.2.2",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.64.0",
    "vitest": "^3.0.5"
  },
  "overrides": {
    "tar": "^7.5.20",
    "esbuild": "^0.25.0"
  }
}
