# Copy this file to .env and fill in real values.
# Development compose.yml reads from .env; production compose.prod.yml
# uses Docker secrets mounted from ./secrets/ (see compose.prod.yml).

# PostgreSQL
POSTGRES_USER=change-me
POSTGRES_PASSWORD=change-me
POSTGRES_DB=planner

# CORS (must match the frontend URL your users will access)
CORS_ORIGIN=https://planner.local

# Email (password reset). Leave RESEND_API_KEY empty to have the API print
# reset links to its own console instead of sending mail - the whole flow
# works locally without a Resend account. EMAIL_FROM must be on a domain
# verified with Resend before real delivery works.
RESEND_API_KEY=
EMAIL_FROM=noreply@planner.local
